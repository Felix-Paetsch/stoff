{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "public-build",
    "baseUrl": "../../",
    "allowSyntheticDefaultImports": true,
    "paths": {
        "@/Core": ["./Core/index"],
        "@/Dev": ["./Dev/Lib"]
    }
  },
  "include": [
        "../../Core/",
        "../../Dev/",
        "../../Embroidery/Lib",
    ]
}
