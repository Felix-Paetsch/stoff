{
    "type": "module",
    "scripts": {
        "dev::typecheck": "npx tsc -p tsconfig.json --noEmit",
        "dev::typecheck::watch": "./Tools/Scripts/watch.sh 'npx tsc -p tsconfig.json --noEmit' 5",

        "dev::server": "cd ./DevEnv/DevServer/ && npm run dev",
        "dev::server::typecheck": "cd ./DevEnv/DevServer/ && npm run dev::typecheck",
        "dev::server::lint": "cd ./DevEnv/DevServer/ && npm run dev::lint",
        "dev::server::lint::watch": "cd ./DevEnv/DevServer/ && npm run dev::lint::watch",
        "dev::server::typecheck::watch": "cd ./DevEnv/DevServer/ && npm run dev::typecheck::watch",
        "dev::server::typecheck_lint::watch": "cd ./DevEnv/DevServer/ && npm run dev::typecheck_lint::watch",

        "dev::check_all": "npm run dev::typecheck && cd ./DevEnv/DevServer/ && npm run dev::typecheck && npm run dev::lint",
        "dev::check_all::watch": "./Tools/Scripts/watch.sh 'npm run dev::typecheck && cd ./DevEnv/DevServer/ && npm run dev::typecheck && npm run dev::lint' 5",
        
        "dev::standalone": "tsx DevEnv/StandAlone/index.js",
        "dev::standalone::watch": "./Tools/Scripts/watch.sh 'npm run dev::standalone' 5",
        "dev::browser": "cd DevEnv/Profiling && npm run dev"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.1.11",
        "@types/express": "^5.0.3",
        "@types/fluent-ffmpeg": "^2.1.27",
        "@types/node": "^24.3.0",
        "autoprefixer": "^10.4.21",
        "browser-sync": "^3.0.4",
        "concurrently": "^9.2.0",
        "fluent-ffmpeg": "^2.1.3",
        "nodemon": "^3.1.10",
        "postcss": "^8.5.6",
        "ts-node": "^1.7.1",
        "tsx": "^4.20.3",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "canvas": "^3.1.2",
        "compression": "^1.8.1",
        "dotenv": "^17.2.1",
        "ejs": "^3.1.10",
        "express": "^5.1.0",
        "pdf-lib": "^1.17.1",
        "sass": "^1.89.2",
        "uuid": "^11.1.0",
        "zod": "^4.3.5"
    },
    "prettier": {
        "tabWidth": 4
    }
}
