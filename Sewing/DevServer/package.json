{
  "name": "devserver",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",

    "dev::lint": "eslint .",
    "dev::typecheck": "npx tsc -p tsconfig.json --noEmit",
    "dev::lint::watch": "../../Tools/Scripts/watch.sh 'npm run dev::lint' 2",
    "dev::typecheck::watch": "../../Tools/Scripts/watch.sh 'npm run dev::typecheck' 2",
    "dev::typecheck_lint::watch": "../../Tools/Scripts/watch.sh 'npm run dev::typecheck && npm run dev::lint' 4",

    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "source-map": "^0.7.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^6.0.4"
  }
}
