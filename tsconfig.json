{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020"],
        "module": "ESNext",
        "moduleResolution": "node",
        "noUncheckedIndexedAccess": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true,
        "strictFunctionTypes": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "allowJs": true,
        "checkJs": false,
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "declaration": false,
        "allowImportingTsExtensions": true,
        "outDir": "./dist",
        "rootDir": "./",
        "baseUrl": "./",
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": ["**/*.ts", "**/*.js", "**/*.d.ts", "geometry/shapes/algorithms/intersect_lines.ts.tmpevEnv/Debug/scenes/triangle.ts.broken", "DevEnv/Debug/scenes/test.ts.broken", "DevEnv/Debug/scenes/index.ts.broken", "DevEnv/Debug/scenes/heart.ts.broken", "DevEnv/Debug/scenes/dev.ts.broken"],
    "exclude": [
        "node_modules",
        "dist",
        "Sewing//DevServer",
    ],
    "ts-node": {
        "esm": true,
        "experimentalSpecifierResolution": "node"
    }
}
