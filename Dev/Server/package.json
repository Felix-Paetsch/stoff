{
  "name": "watch",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "tsc --project tsconfig.client.json",
    "dev": "npm run build:client && concurrently \"tsc --project tsconfig.client.json --watch\" \"tsx watch src/server.ts\"",
    "start": "npm run build:client && tsx src/server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.client.json"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
