{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020"],
        "module": "ESNext",
        "moduleResolution": "node",
        "noUncheckedIndexedAccess": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true,
        "strictFunctionTypes": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "allowJs": false,
        "checkJs": false,
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": false,
        "declaration": false,
        "allowImportingTsExtensions": false,
        "outDir": "./out/build",
        "rootDir": "./",
        "baseUrl": "./",
        "paths": {
            "@/Core": ["Core/index"],
            "@/Dev": ["Dev/Lib"],
            "@/Algorithms": ["Algorithms/index"]
        }
    },
    "include": ["**/*.ts", "**/*.js", "**/*.d.ts", "Algorithms/dubplicate_edges.ts.broken", "Algorithms/shape/self_intersection_free.ts.broken", "Algorithms/shape/modify_self_intersections.ts.broken"],
    "exclude": [
        "node_modules",
        "dist",

        "Dev/Server",
    ],
    "ts-node": {
        "esm": true,
        "experimentalSpecifierResolution": "node"
    }
}
