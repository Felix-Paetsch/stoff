import {
    EPS,
    line_segments_intersect,
    vec_angle_clockwise,
    Vector,
} from "@/Core/geometry";
import { Polyline } from "..";
import { LineSegment } from "@/Core/geometry/types";

export function offset_polyline(
    line: Polyline,
    radius: number,
    toRight: boolean = true,
): Polyline {
    if (radius < 0) {
        radius *= -1;
        toRight = !toRight;
    }

    if (!toRight) {
        line.reverse();
    }

    const new_line = [];

    let prev_left = null; // For angles
    let left = 0;

    while (left < line.length) {
        let right = left + 1;
        while (
            right < line.length &&
            line[left]!.equals(line[right]!, EPS.FINE)
        ) {
            right++;
        }

        if (right > line.length - 1) {
            break;
        }

        if (prev_left === null) {
            // 0.
            const orth = line[right]!.subtract(line[left]!)
                .get_orthogonal()
                .to_len(radius);
            new_line.push(line[left]!.add(orth));
        } else {
            // 1a)
            const vec1 = line[prev_left]!.subtract(line[left]!);
            const vec2 = line[right]!.subtract(line[left]!);
            let angle = vec_angle_clockwise(vec1, vec2, true);
            const center_vec = vec1.rotate(-angle / 2).to_len(radius);
            new_line.push(line[left]!.add(center_vec));
        }

        // 1b)
        const cp = line[left]!.add(line[right]!).scale(0.5);
        const orth = line[right]!.subtract(line[left]!)
            .get_orthogonal()
            .to_len(radius);
        new_line.push(cp.add(orth));

        prev_left = left;
        left = right;
    }

    // 2.
    if (line[left]!.equals(line[line.length - 1]!, EPS.FINE)) {
        left = prev_left!;
    }
    const orth = Vector.orthogonal(line[left]!, line[line.length - 1]!).to_len(
        radius,
    );
    new_line.push(line[line.length - 1]!.add(orth));

    // 3.
    remove_spikes(new_line, line);

    // 4.
    filter_out_cycles(new_line);

    if (!toRight) {
        line.reverse();
        new_line.reverse();
    }

    return new_line;
}

/**
 *
 * 0. Add Very first Point
 * 1. Loop through all lines and add offset vectors to sample points
 * - Line for first point
 * - Line for middle
 * 2. Add Very last point
 * 3. Remove Spikes at the end
 * 4. Remove loops
 *
 */

function filter_out_cycles(abs_sample_points: Vector[]) {
    let i = 0;
    outer: while (i < abs_sample_points.length - 1) {
        const currentSegment: [Vector, Vector] = [
            abs_sample_points[i]!,
            abs_sample_points[i + 1]!,
        ];

        for (let j = i + 2; j < abs_sample_points.length - 1; j++) {
            const nextSegment: [Vector, Vector] = [
                abs_sample_points[j]!,
                abs_sample_points[j + 1]!,
            ];
            const [intersects, intersectionPoint] = line_segments_intersect(
                currentSegment,
                nextSegment,
            );

            if (intersects) {
                abs_sample_points.splice(i + 1, j - i, intersectionPoint);
                i = Math.max(0, i - 1);
                continue outer;
            }
        }

        i++;
    }

    return abs_sample_points;
}

function remove_spikes(abs_sample_points: Vector[], sp: Vector[]) {
    // End side
    let may_have_spike = true;
    while (may_have_spike && abs_sample_points.length > 2) {
        may_have_spike = false;
        const endSeg: LineSegment = [
            abs_sample_points[abs_sample_points.length - 1]!,
            sp[sp.length - 1]!,
        ];
        for (let i = 0; i < abs_sample_points.length - 2; i++) {
            const seg: LineSegment = [
                abs_sample_points[i]!,
                abs_sample_points[i + 1]!,
            ];
            const [intersects] = line_segments_intersect(endSeg, seg);
            if (intersects) {
                abs_sample_points.pop();
                may_have_spike = true;
                break;
            }
        }
    }

    // Start side
    may_have_spike = true;
    while (may_have_spike && abs_sample_points.length > 2) {
        may_have_spike = false;
        const startSeg: LineSegment = [abs_sample_points[0]!, sp[0]!];
        for (let i = 1; i < abs_sample_points.length - 1; i++) {
            const seg: LineSegment = [
                abs_sample_points[i]!,
                abs_sample_points[i + 1]!,
            ];
            const [intersects] = line_segments_intersect(startSeg, seg);
            if (intersects) {
                abs_sample_points.shift();
                may_have_spike = true;
                break;
            }
        }
    }
}
