import { Copy, Polyline, Sketch, Vector } from "@/Core";

export default function () {
    const s = new Sketch();
    const pts = [s.add_point(0, 0), s.add_point(1, 0)] as const;

    const graph = Polyline.from_function(
        (x) => new Vector(x, Math.sin(3 * Math.PI * x)),
    );
    const l = s.add_line(graph, ...pts);

    Copy.line(l, l.p1, l.p2).smooth_out(0.2).smooth_out(0.2).smooth_out(0.2);
    Copy.line(l, l.p1, l.p2).smooth_out(0.2).smooth_out(0.2);
    Copy.line(l, l.p1, l.p2).smooth_out(0.2);

    console.log("EXIT");
    return s;
}
