{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "public-build",
    "rootDir": "src",
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/public/*.ts", "src/fileProcessor.ts", "src/types.ts"]
}
